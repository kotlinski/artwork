# Disable directory browsing
Options -Indexes

# ----------------------------------------------------------------------
# Rewrite engine
# ----------------------------------------------------------------------

# Turning on the rewrite engine is necessary for the following rules and features.
# FollowSymLinks must be enabled for this to work.
<IfModule mod_rewrite.c>
	Options +FollowSymlinks
	RewriteEngine On

	# If you installed CodeIgniter in a subfolder, you will need to
	# change the following line to match the subfolder you need.
	# http://httpd.apache.org/docs/current/mod/mod_rewrite.html#rewritebase
	RewriteBase /

	# ------------------------------------------------------------------
	# Legacy URL redirects (old /album structure -> new URL structure)
	# Keep these BEFORE front-controller rewrite rules.
	# ------------------------------------------------------------------

	# Collapse double /album/album/ prefix into single /album/
	RewriteRule ^album/album/(.*)$ /album/$1 [R=301,L,NC]

	# Old overview/category pages
	RewriteRule ^album/?$ /artwork [R=301,L,NC]
	RewriteRule ^album/(installations|objects|paintings)/?$ /artwork [R=301,L,NC]

	# Project-prefixed legacy image URLs
	RewriteRule ^album/(installations|objects|paintings)/avfallningar-([a-z0-9-]+)/?$ /avfallningar/$2 [R=301,L,NC]
	RewriteRule ^album/(installations|objects|paintings)/under-liv-([a-z0-9-]+)/?$ /under-liv/$2 [R=301,L,NC]
	RewriteRule ^album/(installations|objects|paintings)/bacteria-([a-z0-9-]+)/?$ /bacteria/$2 [R=301,L,NC]
	RewriteRule ^album/(installations|objects|paintings)/liv-no-8-([a-z0-9-]+)/?$ /liv-no-8/$2 [R=301,L,NC]

	# Legacy one-off slug variant in old sitemap
	RewriteRule ^album/(installations|objects|paintings)/life-no-8-construction/?$ /liv-no-8/life-no-8-construction [R=301,L,NC]

	# Images that moved to project "vi-i-villa-liv"
	RewriteRule ^album/(installations|objects|paintings)/(sparris-no-2|rodkal-no-2|lok-no-2|liv-kalmar-konstmuseum|liv-rotundan-kalmar-konstmuseum|vitkal-skulptur|bla-traktor-no-2-gras|traktor-no-2-gras|red-traktor-grass|bla-traktor|gul-traktor|rod-vit-traktor|scener-ur-ett|vi-i-villa-no-[1-5])/?$ /vi-i-villa-liv/$2 [R=301,L,NC]

	# Old unprefixed slugs that now live under bacteria
	RewriteRule ^album/(installations|objects|paintings)/(embryo-sphere-[1-3]|livspiral-3)/?$ /bacteria/$2 [R=301,L,NC]

	# Project "liv" images (keep whole slug as image id)
	RewriteRule ^album/(installations|objects|paintings)/(liv-[a-z0-9-]+)/?$ /liv/$2 [R=301,L,NC]

	# Fallback for any remaining old album image/detail URL
	RewriteRule ^album/(installations|objects|paintings)/[a-z0-9-]+/?$ /artwork [R=301,L,NC]

	# Redirect Trailing Slashes...
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^(.+)/$ /$1 [L,R=301]


	# Checks to see if the user is attempting to access a valid file,
	# such as an image or css document, if this isn't true it sends the
	# request to the front controller, index.php
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^([\s\S]*)$ index.php/$1 [L,NC,QSA]

	# Ensure Authorization header is passed along
	RewriteCond %{HTTP:Authorization} .
	RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

<IfModule !mod_rewrite.c>
	# If we don't have mod_rewrite installed, all 404's
	# can be sent to index.php, and everything works as normal.
	ErrorDocument 404 index.php
</IfModule>

# Disable server signature start
ServerSignature Off
# Disable server signature end

<IfModule mod_expires.c>
    ExpiresActive On

    # Images
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"

    # CSS and JavaScript
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
	# Long cache for static assets; HTML remains uncached.
	<FilesMatch "\.(?:webp|jpg|jpeg|png|gif|svg|ico|woff2?|ttf|otf)$">
		Header set Cache-Control "public, max-age=31536000"
	</FilesMatch>
	<FilesMatch "\.(?:css|js)$">
		Header set Cache-Control "public, max-age=2592000"
	</FilesMatch>
	<FilesMatch "\.(?:html?|php)$">
		Header set Cache-Control "no-cache, no-store, must-revalidate"
		Header set Pragma "no-cache"
		Header set Expires "0"
	</FilesMatch>
</IfModule>

<IfModule mod_brotli.c>
	AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_deflate.c>
	AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

