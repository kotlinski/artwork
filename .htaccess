# Redirect all requests to the public/ subdirectory.
# Place this file in the web root on shared hosting where you cannot
# change the document root to point directly at public/.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # If someone navigates directly to /public/..., redirect to strip it.
    RewriteCond %{THE_REQUEST} \s/public/(\S*)\s [NC]
    RewriteRule ^ /%1 [R=301,L]

    # Internally rewrite all requests into public/ (invisible to browser).
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L,E=SCRIPT_NAME:/index.php]
</IfModule>

